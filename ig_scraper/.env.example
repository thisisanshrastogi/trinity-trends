# Instagram credentials
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Google Gemini API key — CAPTCHA vision + optional --agent
GOOGLE_API_KEY=your_google_api_key

# Model aliases (always-current -latest flags)
# GEMINI_FLASH_MODEL=gemini-flash-latest   # agent browser / ADK (default)
# GEMINI_PRO_MODEL=gemini-pro-latest       # image-grid captcha (default)
# Or override directly:
# AGENT_BROWSER_MODEL=gemini-flash-latest
# CAPTCHA_MODEL=gemini-pro-latest
